# ── Подключение к PostgreSQL ──────────────────────────────
# Формат: Host=<db-host>;Port=5432;Database=libnode;Username=<user>;Password=<password>
DB_CONNECTION_STRING=Host=db-host.example.invalid;Port=5432;Database=libnode;Username=libnode_user;Password=placeholder-db-password
JWT_SIGNING_KEY=placeholder-long-random-jwt-signing-key-min-32-chars
TRANSLATOR_API_KEY=placeholder-translator-api-key
CORS_ORIGIN=https://reader.example.invalid

# ── URL бэкенда для клиентских запросов из браузера ───────
# Это адрес, по которому БРАУЗЕР пользователя будет обращаться к API.
# В продакшене это должен быть HTTPS origin, иначе браузер заблокирует mixed content.
API_BASE_URL=https://reader.example.invalid

# ── Backend Production Hardening ────────────────────────────
# Swagger UI exposure (false in production, true for dev only)
Swagger__Enabled=false
# ForwardedHeaders: required when API is behind reverse proxy (Docker/Nginx/Traefik)
ForwardedHeaders__Enabled=true
# Rate limiting on auth and ingest endpoints
RateLimiting__Enabled=true
RateLimiting__Auth__PermitLimit=10
RateLimiting__Auth__WindowMinutes=1
RateLimiting__Ingest__PermitLimit=60
RateLimiting__Ingest__WindowMinutes=1
# AllowedHosts: production host name(s) the API will accept
AllowedHosts=libnode-api

# translator stack
TRANSLATOR_WEB_PORT=3005
# Внешний PostgreSQL для translator, формат:
# postgresql://user:password@db-host:5432/libnode_translator
TRANSLATOR_DATABASE_URL=postgresql://translator_user:placeholder-db-password@db-host.example.invalid:5432/libnode_translator
# Внешний Redis для translator, формат:
# redis://redis-host:6379
TRANSLATOR_REDIS_URL=redis://redis.example.invalid:6379
TRANSLATOR_OPENAI_API_KEY=placeholder-openai-api-key
TRANSLATOR_OPENAI_BASE_URL=https://example.invalid/v1
TRANSLATOR_OPENAI_MODEL=gpt-5-mini
TRANSLATOR_LOG_LEVEL=info
TRANSLATOR_PLAYWRIGHT_HEADLESS=new
TRANSLATOR_PLAYWRIGHT_BROWSER_NAME=chromium
TRANSLATOR_PLAYWRIGHT_BROWSER_CHANNEL=
TRANSLATOR_PLAYWRIGHT_EXECUTABLE_PATH=
TRANSLATOR_PLAYWRIGHT_DATA_DIR=./data/translator-playwright
TRANSLATOR_PLAYWRIGHT_STORAGE_STATE_PATH=/data/playwright/novellive.json
TRANSLATOR_PLAYWRIGHT_USER_DATA_DIR=
TRANSLATOR_PLAYWRIGHT_STEALTH=true
TRANSLATOR_PLAYWRIGHT_PROXY_SERVER=
TRANSLATOR_PLAYWRIGHT_PROXY_USERNAME=
TRANSLATOR_PLAYWRIGHT_PROXY_PASSWORD=
TRANSLATOR_CHAPTER_FETCH_RATE_LIMIT_MS=8000
TRANSLATOR_READER_API_MOCK=false
# Production: TRANSLATOR_BASIC_AUTH_ENABLED=true and non-default credentials are REQUIRED.
# The translator will refuse to start if credentials are admin/admin or placeholder-*.
# For local development, set TRANSLATOR_BASIC_AUTH_ENABLED=false (docker-compose.dev.yml does this).
TRANSLATOR_BASIC_AUTH_ENABLED=true
TRANSLATOR_BASIC_AUTH_USERNAME=placeholder-admin-user
TRANSLATOR_BASIC_AUTH_PASSWORD=placeholder-admin-password

# CSRF secret for translator web form protection
TRANSLATOR_CSRF_SECRET=change-me-in-production
