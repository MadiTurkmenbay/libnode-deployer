# ── Подключение к PostgreSQL ──────────────────────────────
# Формат: Host=<ip>;Port=5432;Database=libnode;Username=<user>;Password=<pass>
DB_CONNECTION_STRING=Host=192.168.0.106;Port=5432;Database=libnode;Username=postgres;Password=your_password_here
JWT_SIGNING_KEY=replace_with_long_random_jwt_signing_key_min_32_chars
TRANSLATOR_API_KEY=replace_with_translator_api_key
CORS_ORIGIN=http://localhost:3000

# ── URL бэкенда для клиентских запросов из браузера ───────
# Это адрес, по которому БРАУЗЕР пользователя будет обращаться к API.
# В продакшене это будет внешний домен/IP, например http://api.example.com
API_BASE_URL=http://localhost:5000

# translator stack
TRANSLATOR_WEB_PORT=3005
TRANSLATOR_POSTGRES_DB=libnode_translator
TRANSLATOR_POSTGRES_USER=postgres
TRANSLATOR_POSTGRES_PASSWORD=postgres
TRANSLATOR_OPENAI_API_KEY=replace_with_openai_api_key
TRANSLATOR_OPENAI_BASE_URL=https://api.openai.com/v1
TRANSLATOR_OPENAI_MODEL=gpt-5-mini
TRANSLATOR_LOG_LEVEL=info
TRANSLATOR_PLAYWRIGHT_HEADLESS=true
TRANSLATOR_READER_API_MOCK=false
TRANSLATOR_BASIC_AUTH_ENABLED=false
TRANSLATOR_BASIC_AUTH_USERNAME=admin
TRANSLATOR_BASIC_AUTH_PASSWORD=admin
